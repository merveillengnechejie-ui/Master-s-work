@Article{Lu2025,
  author    = {Jiayi Lu},
  journal   = {Highlights in Science, Engineering and Technology},
  title     = {Nano-based Drug Delivery System for Treating Triple-negative Breast Cancer (TNBC)},
  year      = {2025},
  issn      = {2791-0210},
  month     = feb,
  pages     = {246--256},
  volume    = {125},
  abstract  = {Triple-negative breast cancer (TNBC) is a highly aggressive subtype with limited treatment options, primarily due to the lack of hormone receptors and HER2 expression. Nano-based drug delivery systems, including PEGylated liposomes, polymeric nanoparticles, and gold nanoparticles, present a promising strategy to enhance therapeutic outcomes by improving drug solubility, targeting tumor cells more effectively, and reducing systemic toxicity. These nanoparticles utilize both passive and active targeting mechanisms to address TNBC’s resistance to conventional therapies. This paper reviews the underlying mechanisms, challenges, and current clinical trials of nano-based drug delivery systems for TNBC treatment, emphasizing their role in improving treatment effectiveness and patient results.},
  cites     = {Lu2025a},
  doi       = {10.54097/9fx0rm54},
  publisher = {Darcy & Roy Press Co. Ltd.},
}

