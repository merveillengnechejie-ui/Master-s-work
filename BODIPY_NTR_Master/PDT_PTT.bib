@Article{Hala’ufia2025,
  author    = {Hala’ufia, Moana E. and Roman, David L.},
  journal   = {The Journal of Pharmacology and Experimental Therapeutics},
  title     = {Store-operated calcium entry-based targets for novel cancer therapeutic development},
  year      = {2025},
