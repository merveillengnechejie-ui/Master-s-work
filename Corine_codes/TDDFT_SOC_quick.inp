! UKS wB97X-D3 def2-SVP ZORA RIJCOSX AutoAux TightSCF
! CPCM
! SMD

%pal
  nprocs 4
end
%maxcore 3500

%cpcm
  SMDSolvent "mixed"  # for more complex biological media
end

%tddft
  nstates 10
  ntrips 10
  dosoc true
end

* xyzfile 0 1 S0_water_opt.xyz

# Notes:
# - Fast SOC estimate using TD-DFT (good for screening trends)
# - Not a substitute for NEVPT2 for final values
