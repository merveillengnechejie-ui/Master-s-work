! UKS wB97X-D3 def2-SVP ZORA RIJCOSX AutoAux TightSCF
! CPCM
! SMD

%pal
  nprocs 4
end

%maxcore 3500

%cpcm
  SMDSolvent "mixed"  # for more complex biological media
end

%tddft
  nroots 10      # Calculate 10 singlet states
  triplets true  # Also calculate 10 triplet states
end

* xyzfile 0 1 S0_water_opt.xyz

# Notes:
# - Use the S0 optimized geometry in mixed biological media (S0_water_opt.xyz)
# - Replaces ADC(2) for fast local laptop calculation of absorption spectra.
# - Output will contain vertical excitation energies (look for "ABSORPTION SPECTRUM").
# - Base def2-SVP is used for speed on 4 cores. If > 8GB RAM later, can test def2-TZVP.
